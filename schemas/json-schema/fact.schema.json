{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fact.schema.json",
  "title": "Fact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fact_id",
    "fact_type",
    "statement",
    "provenance",
    "observed_at",
    "evidence_refs",
    "scope",
    "confidence",
    "status",
    "version"
  ],
  "properties": {
    "fact_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "fact_type": { "$ref": "./defs.schema.json#/$defs/FactType" },
    "statement": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" },
    "provenance": {
      "oneOf": [
        { "$ref": "./defs.schema.json#/$defs/NonEmptyString" },
        { "$ref": "./defs.schema.json#/$defs/FlexibleObject" }
      ]
    },
    "evidence_refs": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "scope": { "$ref": "./defs.schema.json#/$defs/FlexibleObject" },
    "observed_at": { "$ref": "./defs.schema.json#/$defs/Timestamp" },
    "verified_at": { "$ref": "./defs.schema.json#/$defs/Timestamp" },
    "valid_until": { "$ref": "./defs.schema.json#/$defs/Timestamp" },
    "ttl": {
      "type": "integer",
      "minimum": 0
    },
    "attestation_level": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "supersedes": { "$ref": "./defs.schema.json#/$defs/Id" },
    "conflict_set": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "status": { "$ref": "./defs.schema.json#/$defs/FactStatus" },
    "version": {
      "type": "integer",
      "minimum": 0
    }
  }
}
