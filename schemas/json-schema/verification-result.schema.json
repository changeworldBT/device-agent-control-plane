{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "verification-result.schema.json",
  "title": "VerificationResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verification_id",
    "task_id",
    "node_id",
    "receipt_refs",
    "result",
    "supporting_evidence",
    "remaining_uncertainties",
    "state_transition",
    "verified_at",
    "verifier_id"
  ],
  "properties": {
    "verification_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "task_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "node_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "receipt_refs": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "result": { "$ref": "./defs.schema.json#/$defs/VerificationResult" },
    "supporting_evidence": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "remaining_uncertainties": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "state_transition": { "$ref": "./defs.schema.json#/$defs/FlexibleObject" },
    "recommended_recovery_action": { "$ref": "./defs.schema.json#/$defs/RecoveryAction" },
    "verified_at": { "$ref": "./defs.schema.json#/$defs/Timestamp" },
    "verifier_id": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" }
  }
}
