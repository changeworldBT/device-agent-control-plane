{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "action-spec.schema.json",
  "title": "ActionSpec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action_id",
    "task_id",
    "node_id",
    "action_type",
    "required_capability",
    "target_scope",
    "inputs",
    "preconditions",
    "expected_artifacts",
    "postconditions",
    "budget",
    "idempotency_key"
  ],
  "properties": {
    "action_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "task_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "node_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "action_type": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" },
    "required_capability": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" },
    "target_scope": { "$ref": "./defs.schema.json#/$defs/FlexibleObject" },
    "inputs": { "$ref": "./defs.schema.json#/$defs/FlexibleObject" },
    "preconditions": {
      "oneOf": [
        { "$ref": "./defs.schema.json#/$defs/FlexibleObject" },
        { "$ref": "./defs.schema.json#/$defs/FlexibleArray" }
      ]
    },
    "expected_artifacts": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "postconditions": {
      "oneOf": [
        { "$ref": "./defs.schema.json#/$defs/FlexibleObject" },
        { "$ref": "./defs.schema.json#/$defs/FlexibleArray" }
      ]
    },
    "budget": { "$ref": "./defs.schema.json#/$defs/FlexibleObject" },
    "idempotency_key": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" },
    "grant_ref": { "$ref": "./defs.schema.json#/$defs/Id" },
    "compensation_policy_ref": { "$ref": "./defs.schema.json#/$defs/Id" },
    "side_effect_class": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" }
  }
}
