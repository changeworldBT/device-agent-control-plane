{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "state-capsule.schema.json",
  "title": "StateCapsule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capsule_id",
    "capsule_type",
    "task_id",
    "node_id",
    "objective",
    "desired_delta",
    "current_task_state",
    "verified_facts",
    "open_questions",
    "hard_constraints",
    "soft_constraints",
    "active_grants_summary",
    "relevant_artifacts",
    "recent_decisions",
    "pending_dependencies",
    "candidate_next_actions",
    "failure_or_recovery_context",
    "freshness_markers",
    "validator_ref",
    "generated_at",
    "generator_ref"
  ],
  "properties": {
    "capsule_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "capsule_type": { "$ref": "./defs.schema.json#/$defs/CapsuleType" },
    "task_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "node_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "objective": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" },
    "desired_delta": { "$ref": "./defs.schema.json#/$defs/FlexibleObject" },
    "current_task_state": { "$ref": "./defs.schema.json#/$defs/TaskState" },
    "verified_facts": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "open_questions": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "hard_constraints": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "soft_constraints": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "active_grants_summary": { "$ref": "./defs.schema.json#/$defs/FlexibleArray" },
    "relevant_artifacts": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "recent_decisions": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "pending_dependencies": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "candidate_next_actions": { "$ref": "./defs.schema.json#/$defs/FlexibleArray" },
    "failure_or_recovery_context": { "$ref": "./defs.schema.json#/$defs/FlexibleObject" },
    "freshness_markers": { "$ref": "./defs.schema.json#/$defs/FlexibleObject" },
    "validator_ref": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" },
    "generated_at": { "$ref": "./defs.schema.json#/$defs/Timestamp" },
    "generator_ref": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" }
  }
}
