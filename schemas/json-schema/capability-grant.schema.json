{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "capability-grant.schema.json",
  "title": "CapabilityGrant",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "grant_id",
    "task_id",
    "node_id",
    "who",
    "what",
    "where",
    "when",
    "budget",
    "why",
    "approval_ref",
    "postcondition_ref",
    "status",
    "issued_at",
    "expires_at"
  ],
  "properties": {
    "grant_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "task_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "node_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "who": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" },
    "what": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" },
    "where": { "$ref": "./defs.schema.json#/$defs/FlexibleObject" },
    "when": { "$ref": "./defs.schema.json#/$defs/FlexibleObject" },
    "budget": { "$ref": "./defs.schema.json#/$defs/FlexibleObject" },
    "why": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" },
    "approval_ref": { "$ref": "./defs.schema.json#/$defs/Id" },
    "postcondition_ref": { "$ref": "./defs.schema.json#/$defs/Id" },
    "principal_ref": { "$ref": "./defs.schema.json#/$defs/Id" },
    "resource_owner_ref": { "$ref": "./defs.schema.json#/$defs/Id" },
    "approver_ref": { "$ref": "./defs.schema.json#/$defs/Id" },
    "status": { "$ref": "./defs.schema.json#/$defs/GrantStatus" },
    "issued_at": { "$ref": "./defs.schema.json#/$defs/Timestamp" },
    "expires_at": { "$ref": "./defs.schema.json#/$defs/Timestamp" },
    "revocation_reason": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" }
  }
}
