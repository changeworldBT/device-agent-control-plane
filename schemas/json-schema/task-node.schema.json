{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task-node.schema.json",
  "title": "TaskNode",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "node_id",
    "task_id",
    "node_type",
    "objective",
    "desired_delta",
    "evidence_of_done",
    "risk_class",
    "state",
    "dependencies",
    "required_capabilities",
    "version",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "node_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "task_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "parent_node_id": { "$ref": "./defs.schema.json#/$defs/Id" },
    "node_type": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" },
    "objective": { "$ref": "./defs.schema.json#/$defs/NonEmptyString" },
    "desired_delta": { "$ref": "./defs.schema.json#/$defs/FlexibleObject" },
    "evidence_of_done": { "$ref": "./defs.schema.json#/$defs/FlexibleObject" },
    "risk_class": { "$ref": "./defs.schema.json#/$defs/RiskClass" },
    "state": { "$ref": "./defs.schema.json#/$defs/TaskState" },
    "dependencies": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "required_capabilities": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "principal_ref": { "$ref": "./defs.schema.json#/$defs/Id" },
    "resource_owner_ref": { "$ref": "./defs.schema.json#/$defs/Id" },
    "owner_lease_ref": { "$ref": "./defs.schema.json#/$defs/Id" },
    "grant_refs": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "artifact_refs": { "$ref": "./defs.schema.json#/$defs/StringList" },
    "version": {
      "type": "integer",
      "minimum": 0
    },
    "created_at": { "$ref": "./defs.schema.json#/$defs/Timestamp" },
    "updated_at": { "$ref": "./defs.schema.json#/$defs/Timestamp" }
  }
}
